PROJECT_NAME=email_ai_platform
ENVIRONMENT=development

POSTGRES_DB=email_ai
POSTGRES_USER=email_ai_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=

BACKEND_API_KEY=change_me
# Keep false until an approved SES/Listmonk trial is ready to use the backend send path.
EMAIL_SENDING_ENABLED=false
# Use listmonk as the Sendwise-controlled SMTP boundary. Use ses only for sandbox QA after SES domain/DKIM/SPF/DMARC checks pass.
EMAIL_PROVIDER=listmonk
REAL_SEND_ALLOWED_RECIPIENTS=
REAL_SEND_REQUIRE_ALLOWED_RECIPIENTS=true
# First SES validation commonly uses 1 with REAL_SEND_REQUIRE_ALLOWED_RECIPIENTS=true.
# Official trials should use 0 to let campaign limits control audience size.
REAL_SEND_MAX_RECIPIENTS=3
REAL_SEND_ENVIRONMENTS=development,staging,test
REAL_SEND_CONFIRMATION_TOKEN=

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_API_BASE_URL=https://api.clerk.com/v1
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/auth/redirect
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/login
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-instance.clerk.accounts.dev
CLERK_AUDIENCE=
AUTH_USER_MAPPINGS_JSON={"user_clerk_admin_id":{"email":"platform-admin@example.com","access_type":"platform_admin","status":"active"}}
# Client accounts are no longer sourced from AUTH_USER_MAPPINGS_JSON.
# Persist client access in the client_access table after this milestone.

LISTMONK_URL=http://listmonk:9000
LISTMONK_USERNAME=admin
LISTMONK_PASSWORD=change_me
LISTMONK_TIMEOUT_SECONDS=5

# SMTP_HOST must be a bare host only, with no smtp:// or smtps:// prefix.
# Production fallback: keep Sendwise on EMAIL_PROVIDER=listmonk and configure listmonk to relay through Mailgun SMTP.
# Local/dev Mailpit validation should override these SMTP_* values without changing the committed example contract.
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
# SMTP relay auth should use the SMTP relay credentials only.
SMTP_USERNAME=postmaster@send.mailerpro.it
SMTP_PASSWORD=replace_with_mailgun_smtp_password
SMTP_TLS=true
# This sender must belong to the verified sending domain configured in the relay provider.
SMTP_FROM_EMAIL=sendwise@send.mailerpro.it
# Placeholder operator guidance for the sender display name; current committed runtime contract uses SMTP_FROM_EMAIL directly.
SMTP_FROM_NAME=Sendwise
# Required only when EMAIL_PROVIDER=ses for sandbox QA.
AWS_SES_REGION=
SES_CONFIGURATION_SET=

AI_PROVIDER=
AI_API_KEY=
AI_MODEL=

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://backend:8000
# Public unsubscribe links use FRONTEND_URL. Keep BACKEND_PUBLIC_URL as the API origin only.
BACKEND_PUBLIC_URL=http://localhost:8000
UNSUBSCRIBE_TOKEN_SECRET=

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_USE_MOCK_API=false
